{
  "name": "RCC · Remote Claude Code",
  "short_name": "RCC",
  "description": "远程控制你家里那台 Mac 上的 Claude Code，从任何设备。",
  "start_url": "/",
  "scope": "/",
  "id": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#09090b",
  "theme_color": "#09090b",
  "orientation": "any",
  "lang": "zh-CN",
  "dir": "ltr",
  "categories": ["developer", "productivity", "utilities"],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "shortcuts": [
    {
      "name": "新建会话",
      "short_name": "新建",
      "description": "直接打开新建会话向导",
      "url": "/?action=new-session",
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    },
    {
      "name": "收件箱",
      "short_name": "收件箱",
      "description": "查看审批与通知",
      "url": "/?action=inbox",
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    }
  ],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
